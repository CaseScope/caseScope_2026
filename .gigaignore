# Ignore everything by default
*

# Re-include only directories needed for current active refactor
!app.py
!config.py
!wsgi.py
!requirements.txt
!version.json
!README.md
!giga_project_context.py

# Core source directories
!models/
!models/**
!parsers/
!parsers/**
!utils/
!utils/**
!routes/
!routes/**
!services/
!services/**
!tasks/
!tasks/**

# Critical docs only
!docs/
!docs/PARSERS.md
!docs/TIMEZONE.md
!docs/refactor/
